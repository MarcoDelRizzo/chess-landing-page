---
const APP_SCREENSHOT =
  "https://media.base44.com/images/public/69c87675c5d51e2a52e1d26d/87bf77bbc_image.png";

const features = [
  {
    label: "AI Mentor Chat",
    desc: "Ask anything about your position. It sees the board, evaluation, and every move.",
    symbol: "✦",
  },
  {
    label: "Real-Time Engine",
    desc: "Depth-24 analysis with best lines and an eval bar, live while you play and review.",
    symbol: "⚡",
  },
  {
    label: "Full Game Review",
    desc: "Accuracy, blunders, mistakes, and brilliant moves in one clean study flow.",
    symbol: "◫",
  },
];
---

<section class="hero section-shell" aria-labelledby="hero-title">
  <nav class="hero__nav" aria-label="Primary">
    <div class="hero__brand">
      <span class="hero__brand-mark">♞</span>
      <span class="hero__brand-name">Chess Mentor</span>
    </div>

    <span class="hero__tag">Coming soon</span>
  </nav>

  <div class="hero__intro">
    <span class="hero__beta-pill">
      <span class="hero__beta-dot"></span>
      Private beta · Limited spots
    </span>

    <h1 id="hero-title">
      Your personal
      <br />
      <span>chess coach,</span>
      <br />
      always on.
    </h1>

    <p class="hero__text">
      Chess Mentor combines a real-time engine, an AI coach that sees your board,
      and full game review, all in one focused desktop app. Be first to try it.
    </p>

    <div class="hero__form-shell" id="waitlist">
      <div id="mailerlite-form-slot" class="mailerlite-slot">
        <style is:inline>
          @import url("https://assets.mlcdn.com/fonts.css?version=1774528");
          #mlb2-39135291.ml-form-embedContainer {
            box-sizing: border-box;
            display: table;
            margin: 0 auto;
            position: static;
            width: 100% !important;
          }

          #mlb2-39135291.ml-form-embedContainer h4,
          #mlb2-39135291.ml-form-embedContainer p,
          #mlb2-39135291.ml-form-embedContainer span,
          #mlb2-39135291.ml-form-embedContainer button {
            text-transform: none !important;
            letter-spacing: normal !important;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-embedWrapper {
            background-color: transparent;
            border: 0;
            border-radius: 0;
            box-sizing: border-box;
            display: inline-block !important;
            margin: 0;
            padding: 0;
            position: relative;
            width: 100%;
            max-width: 32rem;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody,
          #mlb2-39135291.ml-form-embedContainer .ml-form-embedWrapper .ml-form-successBody {
            padding: 0;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-embedContent,
          #mlb2-39135291.ml-form-embedContainer .ml-form-embedWrapper .ml-form-successBody .ml-form-successContent {
            text-align: center;
            margin: 0 0 0.9rem 0;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-embedContent h4,
          #mlb2-39135291.ml-form-embedContainer .ml-form-embedWrapper .ml-form-successBody .ml-form-successContent h4 {
            color: #2c2416;
            font-family: "Playfair Display", serif;
            font-size: 1.85rem;
            font-weight: 700;
            margin: 0 0 0.4rem 0;
            text-align: center;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-embedWrapper .ml-form-embedBody .ml-form-embedContent p,
          #mlb2-39135291.ml-form-embedContainer .ml-form-embedWrapper .ml-form-successBody .ml-form-successContent p {
            color: #6b5744;
            font-family: "Inter", sans-serif;
            font-size: 0.95rem;
            line-height: 1.7;
            margin: 0;
            text-align: center;
          }

          #mlb2-39135291.ml-form-embedContainer form {
            margin: 0;
            width: 100%;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-formContent,
          #mlb2-39135291.ml-form-embedContainer .ml-form-embedSubmit {
            margin: 0;
            width: 100%;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-fieldRow {
            margin: 0 0 0.75rem 0;
            width: 100%;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-field-group input {
            background-color: #ffffff !important;
            color: #2c2416 !important;
            border: 1px solid #d9cfc4 !important;
            border-radius: 0.9rem !important;
            font-family: "Inter", sans-serif !important;
            font-size: 0.95rem !important;
            line-height: 1.2 !important;
            padding: 0.95rem 1rem !important;
            width: 100% !important;
            box-sizing: border-box !important;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-field-group input::placeholder {
            color: #9b8b7a !important;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-embedSubmit button {
            background-color: #8b6b47 !important;
            border: none !important;
            border-radius: 0.9rem !important;
            box-shadow: none !important;
            color: #ffffff !important;
            cursor: pointer;
            font-family: "Inter", sans-serif !important;
            font-size: 0.95rem !important;
            font-weight: 700 !important;
            line-height: 1.2 !important;
            padding: 0.95rem 1.1rem !important;
            width: 100% !important;
            transition: background-color 180ms ease !important;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-embedSubmit button:hover {
            background-color: #7a5c3a !important;
          }

          #mlb2-39135291.ml-form-embedContainer .row-success {
            display: none;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-successContent {
            padding: 1.25rem;
            background: rgba(255, 255, 255, 0.75);
            border: 1px solid #d9cfc4;
            border-radius: 1rem;
          }

          #mlb2-39135291.ml-form-embedContainer .ml-form-successContent h4 {
            margin-bottom: 0.4rem !important;
          }
        </style>

        <div id="mlb2-39135291" class="ml-form-embedContainer ml-subscribe-form ml-subscribe-form-39135291">
          <div class="ml-form-align-center">
            <div class="ml-form-embedWrapper embedForm">
              <div class="ml-form-embedBody ml-form-embedBodyDefault row-form">
                <div class="ml-form-embedContent">
                  <h4>Join waitlist!</h4>
                  <p>Signup for the waitlist and early access.</p>
                </div>

                <form
                  class="ml-block-form"
                  action="https://assets.mailerlite.com/jsonp/2218915/forms/183235010982053667/subscribe"
                  data-code=""
                  method="post"
                  target="_blank"
                >
                  <div class="ml-form-formContent">
                    <div class="ml-form-fieldRow ml-last-item">
                      <div class="ml-field-group ml-field-email ml-validate-email ml-validate-required">
                        <input
                          aria-label="email"
                          aria-required="true"
                          type="email"
                          class="form-control"
                          data-inputmask=""
                          name="fields[email]"
                          placeholder="Email"
                          autocomplete="email"
                        />
                      </div>
                    </div>
                  </div>

                  <input type="hidden" name="ml-submit" value="1" />

                  <div class="ml-form-embedSubmit">
                    <button type="submit" class="primary">Subscribe</button>
                    <button disabled="disabled" style="display: none;" type="button" class="loading">
                      <div class="ml-form-embedSubmitLoad"></div>
                      <span class="sr-only">Loading...</span>
                    </button>
                  </div>

                  <input type="hidden" name="anticsrf" value="true" />
                </form>
              </div>

              <div class="ml-form-successBody row-success">
                <div class="ml-form-successContent">
                  <h4>Thank you!</h4>
                  <p>You have successfully joined our subscriber list.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <script is:inline>
          function ml_webform_success_39135291() {
            var $ = window.ml_jQuery || window.jQuery;
            if (!$) return;
            $('.ml-subscribe-form-39135291 .row-success').show();
            $('.ml-subscribe-form-39135291 .row-form').hide();
          }
        </script>
        <script
          is:inline
          src="https://groot.mailerlite.com/js/w/webforms.min.js?v95037e5bac78f29ed026832ca21a7c7b"
          type="text/javascript"></script>
        <script is:inline>
          fetch("https://assets.mailerlite.com/jsonp/2218915/forms/183235010982053667/takel");
        </script>
      </div>
    </div>

    <p class="hero__helper">No spam, ever. Unsubscribe anytime.</p>
  </div>

  <div class="hero__screenshot-wrap">
    <div class="hero__screenshot-card">
      <img
        src={APP_SCREENSHOT}
        alt="Chess Mentor interface showing the board, move list, and AI mentor panel"
        class="hero__screenshot"
      />
      <div class="hero__screenshot-fade"></div>
    </div>
  </div>

  <div class="hero__features" aria-label="Product features">
    {features.map((feature) => (
      <article class="feature-card">
        <div class="feature-card__icon" aria-hidden="true">{feature.symbol}</div>
        <h2 class="feature-card__title">{feature.label}</h2>
        <p class="feature-card__desc">{feature.desc}</p>
      </article>
    ))}
  </div>
</section>
